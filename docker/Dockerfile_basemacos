# ==============================================================================
# RedisHub macOS Cross-Compilation Base Image
# Optimized for Go 1.24+ and macOS SDK 14.5+
# ==============================================================================

FROM ubuntu:22.04 AS base

# Prevent interactive prompts during apt-get
ENV DEBIAN_FRONTEND=noninteractive

# Build-time arguments
ARG GO_VERSION=1.24.10
ARG SDK_VERSION=14.5
ARG OSXCROSS_REPO=https://github.com/tpoechtrager/osxcross.git

# 1. Install System Dependencies
# ------------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    git \
    build-essential \
    clang \
    llvm-dev \
    libxml2-dev \
    libssl-dev \
    libz-dev \
    liblzma-dev \
    libbz2-dev \
    cmake \
    patch \
    bash \
    python3 \
    python3-pip \
    xz-utils \
    cpio \
    && rm -rf /var/lib/apt/lists/*

# 2. Setup Go Environment
# ------------------------------------------------------------------------------
RUN wget -q https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-amd64.tar.gz && \
    rm go${GO_VERSION}.linux-amd64.tar.gz

ENV PATH="/usr/local/go/bin:${PATH}"

# 3. Setup OSXCROSS
# ------------------------------------------------------------------------------
WORKDIR /osxcross
RUN git clone ${OSXCROSS_REPO} .

# Copy SDK into the standard tarballs directory
# We assume the SDK is provided in the build context at docker/tarballs/
RUN mkdir -p tarballs
COPY docker/tarballs/MacOSX${SDK_VERSION}.sdk.tar.xz tarballs/

# Build OSXCROSS
# We set all variables explicitly to ensure the build script succeeds
ENV UNATTENDED=1
ENV OSXCROSS_SDK_VERSION=${SDK_VERSION}
ENV TARBALL_DIR=/osxcross/tarballs
ENV MACOSX_DEPLOYMENT_TARGET=${SDK_VERSION}

RUN ./build.sh

# Ensure the SDK is in the target directory (sometimes build.sh needs help)
RUN if [ ! -d "/osxcross/target/SDK/MacOSX${SDK_VERSION}.sdk" ]; then \
        echo "Moving SDK to target directory..."; \
        mkdir -p /osxcross/target/SDK; \
        cp -r /osxcross/tarballs/MacOSX${SDK_VERSION}.sdk /osxcross/target/SDK/ 2>/dev/null || \
        cp -r /osxcross/target/sdk/MacOSX${SDK_VERSION}.sdk /osxcross/target/SDK/ 2>/dev/null || \
        echo "SDK already in place or not found"; \
    fi

# 4. Final Environment Configuration
# ------------------------------------------------------------------------------
ENV PATH="/osxcross/target/bin:${PATH}"

# Create generic symlinks for tools to decouple from specific SDK versions
RUN ln -sf /osxcross/target/bin/x86_64-apple-darwin*-clang /osxcross/target/bin/x86_64-apple-darwin-clang && \
    ln -sf /osxcross/target/bin/aarch64-apple-darwin*-clang /osxcross/target/bin/aarch64-apple-darwin-clang && \
    ln -sf /osxcross/target/bin/x86_64-apple-darwin*-lipo /osxcross/target/bin/x86_64-apple-darwin-lipo && \
    ln -sf /osxcross/target/bin/x86_64-apple-darwin*-libtool /osxcross/target/bin/x86_64-apple-darwin-libtool

# Install dmgbuild for Linux-compatible DMG creation
RUN pip3 install --no-cache-dir dmgbuild

# Verification
RUN go version && \
    x86_64-apple-darwin-clang --version && \
    aarch64-apple-darwin-clang --version

WORKDIR /workspace
