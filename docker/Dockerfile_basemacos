# 1. Base Linux image for cross-compilation
FROM ubuntu:22.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV GO_VERSION=1.24.10
ENV OSXCROSS_VERSION=v1.0
ENV SDK_VERSION=14.5

# Install dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    wget \
    git \
    build-essential \
    clang \
    llvm-dev \
    pkg-config \
    cmake \
    patch \
    libxml2-dev \
    libssl-dev \
    zlib1g-dev \
    liblzma-dev \
    libbz2-dev \
    libz-dev \
    bash \
    python3 \
    python3-pip \
    xz-utils \
    cpio \
    && rm -rf /var/lib/apt/lists/*

# Install dmgbuild
RUN pip3 install dmgbuild

# Install Go
RUN wget -q https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-amd64.tar.gz && \
    rm go${GO_VERSION}.linux-amd64.tar.gz

ENV PATH="/usr/local/go/bin:${PATH}"

# Install osxcross
# Note: This requires the macOS SDK to be present in the build context at tarballs/MacOSX${SDK_VERSION}.sdk.tar.xz
WORKDIR /osxcross
RUN git clone https://github.com/tpoechtrager/osxcross.git .

# We expect the SDK to be provided in the 'tarballs' directory
# Ensure the directory exists
RUN mkdir -p /osxcross/tarballs
COPY docker/tarballs/ /osxcross/tarballs/

# Build osxcross
# We set OSXCROSS_SDK_VERSION to help the script
ENV OSXCROSS_SDK_VERSION=${SDK_VERSION}
# List files for debugging in CI logs if it fails again
RUN ls -la /osxcross/tarballs/ && \
    UNATTENDED=1 ./build.sh

# Ensure the bin directory is in the path
ENV PATH="/osxcross/target/bin:${PATH}"

# Add generic symlinks if they don't exist
# osxcross usually does this, but let's be safe
RUN ln -sf /osxcross/target/bin/x86_64-apple-darwin*-clang /osxcross/target/bin/x86_64-apple-darwin-clang && \
    ln -sf /osxcross/target/bin/aarch64-apple-darwin*-clang /osxcross/target/bin/aarch64-apple-darwin-clang

# Verification
RUN go version
