# ==============================================================================
# RedisHub macOS Cross-Compilation Base Image
# Optimized for Go 1.24+ and macOS SDK 14.5+
# ==============================================================================

FROM ubuntu:22.04 AS base

# Prevent interactive prompts during apt-get
ENV DEBIAN_FRONTEND=noninteractive

# Build-time arguments (prefixed to avoid conflict with osxcross internal vars)
ARG GO_VERSION=1.24.10
ARG MY_SDK_VERSION=14.5
ARG OSXCROSS_REPO=https://github.com/tpoechtrager/osxcross.git

# 1. Install System Dependencies
# ------------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    git \
    build-essential \
    clang \
    llvm-dev \
    libxml2-dev \
    libssl-dev \
    libz-dev \
    liblzma-dev \
    libbz2-dev \
    cmake \
    patch \
    bash \
    python3 \
    python3-pip \
    xz-utils \
    cpio \
    && rm -rf /var/lib/apt/lists/*

# 2. Setup Go Environment
# ------------------------------------------------------------------------------
RUN wget -q https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-amd64.tar.gz && \
    rm go${GO_VERSION}.linux-amd64.tar.gz

ENV PATH="/usr/local/go/bin:${PATH}"

# 3. Setup OSXCROSS
# ------------------------------------------------------------------------------
WORKDIR /osxcross
RUN git clone ${OSXCROSS_REPO} .

# Copy SDK into the standard tarballs directory
# We assume the SDK is provided in the build context at docker/tarballs/
RUN mkdir -p tarballs
COPY docker/tarballs/MacOSX${MY_SDK_VERSION}.sdk.tar.xz tarballs/

# Build OSXCROSS
# We set OSXCROSS_SDK_VERSION to help the script find it
RUN UNATTENDED=1 OSXCROSS_SDK_VERSION=${MY_SDK_VERSION} ./build.sh

# 4. Final Environment Configuration
# ------------------------------------------------------------------------------
ENV PATH="/osxcross/target/bin:${PATH}"

# Crucial: Link the SDK to a generic name that wrappers can always find
# Also ensure the compilers have generic names
RUN ln -sf /osxcross/target/SDK/MacOSX${MY_SDK_VERSION}.sdk /osxcross/target/SDK/MacOSX.sdk && \
    ln -sf /osxcross/target/bin/x86_64-apple-darwin*-clang /osxcross/target/bin/x86_64-apple-darwin-clang && \
    ln -sf /osxcross/target/bin/aarch64-apple-darwin*-clang /osxcross/target/bin/aarch64-apple-darwin-clang && \
    ln -sf /osxcross/target/bin/x86_64-apple-darwin*-lipo /osxcross/target/bin/x86_64-apple-darwin-lipo

# Install dmgbuild
RUN pip3 install --no-cache-dir dmgbuild

# Verification
# We set MACOS_SDK_VERSION here for the verification run
RUN go version && \
    OSXCROSS_SDK_VERSION=${MY_SDK_VERSION} x86_64-apple-darwin-clang --version && \
    OSXCROSS_SDK_VERSION=${MY_SDK_VERSION} aarch64-apple-darwin-clang --version

WORKDIR /workspace
