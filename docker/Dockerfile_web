# 1. Base Node image
FROM node:22-alpine AS node-base
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# libc6-compat is required by some native deps
RUN apk add --no-cache libc6-compat


# 2. Install frontend deps
FROM node-base AS next-deps

ARG SHELL_DIR=shell

COPY ${SHELL_DIR}/package.json \
    ${SHELL_DIR}/yarn.lock* \
    ${SHELL_DIR}/package-lock.json* \
    ${SHELL_DIR}/pnpm-lock.yaml* \
    ${SHELL_DIR}/.npmrc* \
    ./

RUN set -eux; \
    if [ -f yarn.lock ]; then \
    yarn install --frozen-lockfile; \
    elif [ -f package-lock.json ]; then \
    npm ci; \
    elif [ -f pnpm-lock.yaml ]; then \
    corepack enable pnpm && pnpm install --frozen-lockfile; \
    else \
    echo "No lockfile found" && exit 1; \
    fi


# 3. Build frontend
FROM node-base AS next-builder
WORKDIR /app

ARG SHELL_DIR=shell
ARG BUILD_ENV=production
ARG ENV_FILE=${SHELL_DIR}/.env.${BUILD_ENV}

COPY --from=next-deps /app/node_modules ./node_modules
COPY ${SHELL_DIR}/ ./

# Explicit env copy
COPY ${ENV_FILE} .env.production

RUN set -eux; \
    if [ -f yarn.lock ]; then \
    yarn build; \
    elif [ -f package-lock.json ]; then \
    npm run build; \
    elif [ -f pnpm-lock.yaml ]; then \
    corepack enable pnpm && pnpm run build; \
    else \
    echo "No lockfile found" && exit 1; \
    fi

# 4. Go + Web builder
FROM golang:1.26-alpine AS web-builder

RUN apk add --no-cache gcc musl-dev

WORKDIR /workspace

# Cache Go modules
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Inject frontend artifacts
COPY --from=next-builder /app/dist /workspace/.scorix/dist

# Build image
RUN CGO_ENABLED=1 GOOS=linux go build -tags server -ldflags "-s -w" -o /workspace/redishub .


# 5. Final Runner
FROM alpine:latest
WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata

# Copy binary and configuration
COPY --from=web-builder /workspace/redishub /app/redishub
COPY --from=web-builder /workspace/etc/app.yaml /app/etc/app.yaml

# Set environment variables for scorix web mode
ENV SCORIX_MODE=web
ENV SCORIX_WEB_HOST=0.0.0.0
ENV SCORIX_WEB_PORT=8080

# Overwrite config values in etc/app.yaml with environment variables
RUN sed -i "s/^mode:.*/mode: ${SCORIX_MODE}/" etc/app.yaml && \
    sed -i "/^web:/,/port:/ s/^\( *\)host:.*/\1host: ${SCORIX_WEB_HOST}/" etc/app.yaml && \
    sed -i "/^web:/,/port:/ s/^\( *\)port:.*/\1port: ${SCORIX_WEB_PORT}/" etc/app.yaml

EXPOSE 8080

# Run the application
CMD ["/app/redishub"]
