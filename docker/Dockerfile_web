FROM node:22-alpine AS node-base
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# libc6-compat is required by some native deps
RUN apk add --no-cache libc6-compat


FROM node-base AS next-deps

ARG SHELL_DIR=shell

COPY ${SHELL_DIR}/package.json \
    ${SHELL_DIR}/yarn.lock* \
    ${SHELL_DIR}/package-lock.json* \
    ${SHELL_DIR}/pnpm-lock.yaml* \
    ${SHELL_DIR}/.npmrc* \
    ./

RUN set -eux; \
    if [ -f yarn.lock ]; then \
    yarn install --frozen-lockfile; \
    elif [ -f package-lock.json ]; then \
    npm ci; \
    elif [ -f pnpm-lock.yaml ]; then \
    corepack enable pnpm && pnpm install --frozen-lockfile; \
    else \
    echo "No lockfile found" && exit 1; \
    fi


FROM node-base AS next-builder
WORKDIR /app

ARG SHELL_DIR=shell
ARG BUILD_ENV=production
ARG ENV_FILE=${SHELL_DIR}/.env.${BUILD_ENV}

COPY --from=next-deps /app/node_modules ./node_modules
COPY ${SHELL_DIR}/ ./
COPY ${ENV_FILE} .env.production

RUN mkdir -p public/monaco-editor && cp -r node_modules/monaco-editor/min/vs public/monaco-editor/vs

RUN set -eux; \
    if [ -f yarn.lock ]; then \
    yarn build; \
    elif [ -f package-lock.json ]; then \
    npm run build; \
    elif [ -f pnpm-lock.yaml ]; then \
    corepack enable pnpm && pnpm run build; \
    else \
    echo "No lockfile found" && exit 1; \
    fi


FROM golang:1.26-alpine AS web-builder

RUN apk add --no-cache gcc musl-dev

WORKDIR /workspace

COPY go.mod go.sum ./
RUN go mod download

COPY . .
COPY --from=next-builder /app/dist /workspace/.scorix/dist

RUN CGO_ENABLED=1 GOOS=linux go build -tags server -ldflags "-s -w" -o /workspace/redishub .


FROM alpine:latest
WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata

# Config is embedded in the binary (//go:embed scorix.yaml), so no config file
# is shipped or rewritten at runtime — everything is set via env, read by scorix
# at startup (SCORIX_MODE selects web mode; SCORIX_WEB_HOST/PORT set the listen addr).
COPY --from=web-builder /workspace/redishub /app/redishub

ENV SCORIX_MODE=web
ENV SCORIX_WEB_HOST=0.0.0.0
ENV SCORIX_WEB_PORT=8080

EXPOSE 8080

CMD ["/app/redishub"]
